{
  "name": "libretto-playground",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "libretto:status": "libretto status",
    "libretto:setup": "libretto setup",
    "libretto:close-session": "libretto close --session",
    "libretto:close-all": "libretto close --all",
    "run:example": "libretto run src/workflows/scrape-page.ts --headless",
    "run:fubon-statements": "libretto run src/workflows/fubon-statements.ts --headed",
    "run:fubon-credit-card-statements": "libretto run src/workflows/fubon-credit-card-statements.ts --headed",
    "run:fubon-loan-statements": "libretto run src/workflows/fubon-loan-statements.ts --headed",
    "run:yuanta-statements": "libretto run src/workflows/yuanta-statements.ts --headed",
    "run:yuanta-foreign-currency-statements": "libretto run src/workflows/yuanta-foreign-currency-statements.ts --headed",
    "run:yuanta-loan-statements": "libretto run src/workflows/yuanta-loan-statements.ts --headed",
    "run:yuanta-credit-card-statements": "libretto run src/workflows/yuanta-credit-card-statements.ts --headed",
    "run:cathay-statements": "libretto run src/workflows/cathay-statements.ts --headed",
    "run:cathay-foreign-statements": "libretto run src/workflows/cathay-foreign-statements.ts --headed",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ai-sdk/openai": "^2.0.0",
    "libretto": "^0.6.31",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "typescript": "^5.9.0"
  }
}
