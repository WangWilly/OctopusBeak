{
  "name": "octopus-beak",
  "version": "0.5.1",
  "private": true,
  "license": "FSL-1.1-MIT",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "test": "node --no-warnings --experimental-strip-types --test \"src/**/*.check.ts\" \"src/**/*.test.ts\" \"electron/**/*.check.ts\" \"electron/**/*.check.cjs\" \"scripts/**/*.check.mjs\"",
    "test:ci": "mkdir -p reports && node --no-warnings --experimental-strip-types --experimental-test-coverage --test --test-reporter=spec --test-reporter-destination=reports/test-summary.txt --test-reporter=junit --test-reporter-destination=reports/junit.xml \"src/**/*.check.ts\" \"src/**/*.test.ts\" \"electron/**/*.check.ts\" \"electron/**/*.check.cjs\" \"scripts/**/*.check.mjs\"",
    "postinstall": "node scripts/patch-libretto-run-cdp.mjs",
    "build": "npm run build:renderer && npm run build:electron",
    "build:renderer": "vite build",
    "build:electron": "vite build --config electron.vite.config.ts",
    "site:dev": "vite site --host 127.0.0.1 --port 4173",
    "preview": "vite preview",
    "typecheck": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json && tsc --noEmit",
    "desktop:dev": "npm run build && electron .",
    "desktop:dev:mock": "npm run run:seed-mock-ledger-db -- \"$PWD/data/mock-desktop/data/ledger\" && OCTOPUSBEAK_USER_DATA=\"$PWD/data/mock-desktop\" npm run desktop:dev",
    "desktop:package": "npm run build && npm run desktop:install-browsers && electron-forge package",
    "desktop:make": "npm run build && npm run desktop:install-browsers && electron-forge make",
    "desktop:make:signed": "OCTOPUSBEAK_SIGN=1 npm run desktop:make",
    "desktop:install-browsers": "PLAYWRIGHT_BROWSERS_PATH=0 npx playwright install chromium",
    "desktop:runtime-probe": "ELECTRON_RUN_AS_NODE=1 electron electron/runtime-probe.cjs",
    "desktop:strip-types-probe": "ELECTRON_RUN_AS_NODE=1 electron --experimental-strip-types electron/strip-types-probe.ts",
    "patch:libretto": "node scripts/patch-libretto-run-cdp.mjs",
    "check:package-lock": "node scripts/check-package-lock.mjs",
    "check:libretto-patch": "node scripts/patch-libretto-run-cdp.check.mjs",
    "libretto:status": "libretto status",
    "libretto:setup": "libretto setup",
    "libretto:close-session": "libretto close --session",
    "libretto:close-all": "libretto close --all",
    "run:example": "libretto run src/workflows/scrape-page.ts --headless",
    "run:fubon-statements": "libretto run src/workflows/fubon-statements.ts --headless",
    "run:fubon-all-statements": "libretto run src/workflows/fubon-all-statements.ts --headless",
    "run:fubon-credit-card-statements": "libretto run src/workflows/fubon-credit-card-statements.ts --headless",
    "run:fubon-loan-statements": "libretto run src/workflows/fubon-loan-statements.ts --headless",
    "run:esun-credit-card-statements": "libretto run src/workflows/esun-credit-card-statements.ts --headless",
    "run:yuanta-statements": "libretto run src/workflows/yuanta-statements.ts --headless",
    "run:yuanta-all-statements": "libretto run src/workflows/yuanta-all-statements.ts --headless",
    "run:yuanta-trade-statements": "libretto run src/workflows/yuanta-trade-statements.ts --headless",
    "run:yuanta-foreign-currency-statements": "libretto run src/workflows/yuanta-foreign-currency-statements.ts --headless",
    "run:yuanta-loan-statements": "libretto run src/workflows/yuanta-loan-statements.ts --headless",
    "run:yuanta-credit-card-statements": "libretto run src/workflows/yuanta-credit-card-statements.ts --headless",
    "run:yuanta-fund-statements": "libretto run src/workflows/yuanta-fund-statements.ts --headless",
    "run:cathay-statements": "libretto run src/workflows/cathay-statements.ts --headless",
    "run:cathay-all-statements": "libretto run src/workflows/cathay-all-statements.ts --headless",
    "run:cathay-foreign-statements": "libretto run src/workflows/cathay-foreign-statements.ts --headless",
    "run:hncb-statements": "libretto run src/workflows/hncb-statements.ts --headless",
    "run:ctbc-statements": "libretto run src/workflows/ctbc-statements.ts --headless",
    "run:post-statements": "libretto run src/workflows/post-statements.ts --headless",
    "run:sinopac-statements": "libretto run src/workflows/sinopac-statements.ts",
    "run:linebank-statements": "libretto run src/workflows/linebank-statements.ts --headless",
    "run:einvoice-personal-invoices": "libretto run src/workflows/einvoice-personal-invoices.ts --headless",
    "run:import-downloads-csv": "node --no-warnings --experimental-strip-types src/ledger/import-downloads-csv.ts",
    "run:sync-maicoin": "node --env-file-if-exists=.env --no-warnings --experimental-strip-types src/ledger/sync-maicoin.ts",
    "run:exchange-rates": "node --no-warnings --experimental-strip-types src/ledger/sync-exchange-rates.ts",
    "run:migrate-ledger-db": "node --no-warnings --experimental-strip-types src/ledger/migrate-ledger-db.ts",
    "run:seed-mock-ledger-db": "node --no-warnings --experimental-strip-types src/ledger/seed-mock-ledger-db.ts",
    "privacy-check": ".githooks/pre-commit",
    "secrets-check": "gitleaks dir . --config .gitleaks.toml --redact --verbose",
    "hooks:install": "git config core.hooksPath .githooks"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.2",
    "libretto": "^0.6.31",
    "playwright": "^1.61.0",
    "xlsx": "^0.18.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.11.2",
    "@electron-forge/maker-dmg": "^7.11.2",
    "@electron-forge/maker-zip": "^7.11.2",
    "@lucide/svelte": "^1.25.0",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.68.0",
    "@types/node": "^26.0.0",
    "electron": "^43.0.0",
    "layerchart": "^2.0.0",
    "svelte": "^5.56.4",
    "svelte-check": "^4.7.1",
    "typescript": "^5.9.0",
    "vite": "^8.1.0"
  }
}
