# Developer-only fallback for direct workflow runs.
# The desktop automation panel stores app settings in settings.json and
# credential values in credentials.json.
# Direct libretto run commands read exported shell env. An ignored .env.local
# file is manual only: set -a; source .env.local; set +a
AUTOMATION_BUSINESS_TIMEZONE=Asia/Taipei

# Fubon e-bank workflow credentials.
LIBRETTO_CLOUD_FUBON_ENABLED=true
LIBRETTO_CLOUD_FUBON_USER_ID=
LIBRETTO_CLOUD_FUBON_ACCOUNT=
LIBRETTO_CLOUD_FUBON_PASSWORD=

# ESun e-bank workflow credentials.
LIBRETTO_CLOUD_ESUN_ENABLED=true
LIBRETTO_CLOUD_ESUN_USER_ID=
LIBRETTO_CLOUD_ESUN_ACCOUNT=
LIBRETTO_CLOUD_ESUN_PASSWORD=

# Yuanta e-bank workflow credentials.
LIBRETTO_CLOUD_YUANTA_ENABLED=true
LIBRETTO_CLOUD_YUANTA_USER_ID=
LIBRETTO_CLOUD_YUANTA_ACCOUNT=
LIBRETTO_CLOUD_YUANTA_PASSWORD=

# YuanTa Nexus WebTrade workflow credentials.
LIBRETTO_CLOUD_YUANTA_TRADE_ENABLED=true
LIBRETTO_CLOUD_YUANTA_TRADE_USER_ID=
LIBRETTO_CLOUD_YUANTA_TRADE_PASSWORD=
LIBRETTO_CLOUD_YUANTA_TRADE_CA_PATH=
LIBRETTO_CLOUD_YUANTA_TRADE_CA_PASSWORD=

LIBRETTO_CLOUD_CATHAY_ENABLED=true
LIBRETTO_CLOUD_CATHAY_USER_ID=
LIBRETTO_CLOUD_CATHAY_ACCOUNT=
LIBRETTO_CLOUD_CATHAY_PASSWORD=

# HNCB e-bank workflow credentials.
LIBRETTO_CLOUD_HNCB_ENABLED=true
LIBRETTO_CLOUD_HNCB_USER_ID=
LIBRETTO_CLOUD_HNCB_ACCOUNT=
LIBRETTO_CLOUD_HNCB_PASSWORD=

# MAX/MaiCoin API credentials.
MAX_ENABLED=true
MAX_ACCESS_KEY=
MAX_SECRET_KEY=
MAX_SUB_ACCOUNT=main
